{% comment %}
  Champagne de Lossy — Heritage intro + parallax image band
  Centered intro (heading + paragraph + Explore link), followed by a
  full-width row of image panels whose backgrounds are fixed (parallax).
  Block field ids kept (image / heading / body …) for backward compatibility.
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="cdl-story color-{{ section.settings.color_scheme }} section section--full-width"
  style="{% render 'spacing-padding', settings: section.settings %} --cols: {{ section.settings.columns }}; --panel-h: {{ section.settings.panel_height }}px;"
>
  {%- if section.settings.heading != blank or section.settings.intro != blank -%}
    <div class="page-width cdl-story__intro">
      {%- if section.settings.heading != blank -%}
        <h2 class="cdl-story__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <div class="cdl-story__intro-body">{{ section.settings.intro }}</div>
      {%- endif -%}
      {%- if section.settings.explore_text != blank -%}
        <a class="cdl-story__explore" href="{{ section.settings.explore_link | default: '#' }}">{{ section.settings.explore_text }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="cdl-story__panels">
      {%- for block in section.blocks -%}
        <div
          class="cdl-story__panel{% if block.settings.image == blank %} cdl-story__panel--empty{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <img
              class="cdl-story__panel-img"
              src="{{ block.settings.image | image_url: width: 1800 }}"
              alt="{{ block.settings.heading | escape }}"
              loading="lazy"
              width="1800"
              height="1200"
            >
          {%- else -%}
            <span class="cdl-monogram" aria-hidden="true">DL</span>
          {%- endif -%}

          {%- if section.settings.show_panel_text and block.settings.heading != blank -%}
            <div class="cdl-story__panel-text">
              {%- if block.settings.eyebrow != blank -%}<p class="cdl-story__panel-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
              <h3 class="cdl-story__panel-title">{{ block.settings.heading }}</h3>
              {%- if block.settings.body != blank -%}<div class="cdl-story__panel-body">{{ block.settings.body }}</div>{%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .cdl-story { --cdl-gold: #b08d57; }

  /* ── Intro ── */
  .cdl-story__intro {
    text-align: center;
    max-width: 64rem;
    margin-inline: auto;
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .cdl-story__title {
    font-family: var(--font-heading--family);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(2.1rem, 5.5vw, 4.5rem);
    line-height: 1.04;
    letter-spacing: 0.01em;
    margin: 0 0 1.5rem;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  .cdl-story__intro-body {
    max-width: 44rem;
    margin: 0 auto 2rem;
    font-family: var(--font-body--family);
    font-size: clamp(0.98rem, 1.1vw, 1.08rem);
    line-height: 1.85;
    color: var(--color-foreground);
    opacity: 0.85;
  }

  .cdl-story__intro-body p { margin: 0 0 1rem; }
  .cdl-story__intro-body p:last-child { margin-bottom: 0; }

  .cdl-story__explore {
    display: inline-block;
    font-family: var(--font-subheading--family);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--cdl-gold);
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--cdl-gold);
    transition: opacity 0.3s ease, letter-spacing 0.3s ease;
  }
  .cdl-story__explore:hover { opacity: 0.75; letter-spacing: 0.3em; }

  /* ── Parallax image band ── */
  .cdl-story__panels {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: 10px;
    padding-inline: clamp(10px, 2vw, 28px);
  }

  .cdl-story__panel {
    position: relative;
    min-height: var(--panel-h, 560px);
    overflow: hidden;
    display: grid;
    place-items: center;
  }

  .cdl-story__panel-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* small overflow gives the parallax room to drift without showing gaps */
    transform: scale(1.1);
    will-change: transform;
  }

  .cdl-story__panel--empty {
    background-image: linear-gradient(150deg, #f6efe2 0%, #e7d8bf 100%);
    border: 1px solid rgba(176, 141, 87, 0.3);
  }

  .cdl-monogram {
    font-family: var(--font-heading--family);
    font-size: clamp(3rem, 6vw, 5.5rem);
    letter-spacing: 0.1em;
    color: rgba(154, 118, 66, 0.4);
  }

  /* Optional caption overlay on a panel */
  .cdl-story__panel-text {
    position: relative;
    z-index: 2;
    max-width: 30rem;
    padding: 2rem;
    text-align: center;
    color: #fff;
    text-shadow: 0 1px 24px rgba(0, 0, 0, 0.4);
  }
  .cdl-story__panel:not(.cdl-story__panel--empty):has(.cdl-story__panel-text)::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(20, 16, 12, 0.28);
    z-index: 1;
  }
  .cdl-story__panel-eyebrow {
    font-family: var(--font-subheading--family);
    font-size: 0.7rem; letter-spacing: 0.26em; text-transform: uppercase;
    color: #fff; opacity: 0.85; margin: 0 0 0.75rem;
  }
  .cdl-story__panel-title {
    font-family: var(--font-heading--family);
    font-weight: 400; text-transform: uppercase;
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    margin: 0 0 0.75rem; color: #fff;
  }
  .cdl-story__panel-body {
    font-family: var(--font-body--family);
    font-size: 0.95rem; line-height: 1.7; color: #fff; opacity: 0.92;
  }

  @media (prefers-reduced-motion: reduce) {
    .cdl-story__panel-img { transform: none; }
  }

  @media screen and (max-width: 749px) {
    .cdl-story__panels { grid-template-columns: 1fr; }
    .cdl-story__panel { min-height: clamp(300px, 60vw, 440px); }
  }
{% endstylesheet %}

<script>
  (function () {
    if (window.__cdlStoryParallax) return;
    window.__cdlStoryParallax = true;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    function update() {
      var vh = window.innerHeight;
      var imgs = document.querySelectorAll('.cdl-story__panel-img');
      for (var i = 0; i < imgs.length; i++) {
        var img = imgs[i];
        var rect = img.parentElement.getBoundingClientRect();
        if (rect.bottom < -50 || rect.top > vh + 50) continue;
        // progress ≈ -0.5 (panel below) → 0.5 (panel above), 0 at viewport center
        var progress = (rect.top + rect.height / 2 - vh / 2) / vh;
        var y = (-progress * rect.height * 0.04).toFixed(1);
        img.style.transform = 'translate3d(0,' + y + 'px,0) scale(1.1)';
      }
    }

    var ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () { update(); ticking = false; });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    window.addEventListener('load', update);
    update();
  })();
</script>

{% schema %}
{
  "name": "Champagne Story",
  "tag": "section",
  "class": "section-cdl-story",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Living Beautifully Since 1862" },
    { "type": "richtext", "id": "intro", "label": "Intro paragraph", "default": "<p>The first day of summer, an intimate family evening, meeting a new partner… why wait on special occasions when so many moments of life deserve to be celebrated? Nestled on the Montagne de Reims, in the renowned village of Rilly-la-Montagne, our House crafts bright and sophisticated champagnes that take each occasion to another level of pleasure and sophistication.</p>" },
    { "type": "text", "id": "explore_text", "label": "Link label", "default": "Explore" },
    { "type": "url", "id": "explore_link", "label": "Link" },
    { "type": "header", "content": "Image band" },
    { "type": "range", "id": "columns", "label": "Images per row", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "range", "id": "panel_height", "label": "Image height", "min": 300, "max": 820, "step": 10, "unit": "px", "default": 560 },
    { "type": "checkbox", "id": "show_panel_text", "label": "Show caption text over images", "default": false },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 40 }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Image panel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select",
          "id": "media_position",
          "label": "Image position (unused in band layout)",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        { "type": "text", "id": "eyebrow", "label": "Caption eyebrow" },
        { "type": "text", "id": "heading", "label": "Caption heading" },
        { "type": "richtext", "id": "body", "label": "Caption text" },
        { "type": "text", "id": "button_text", "label": "Button label (unused)" },
        { "type": "url", "id": "button_link", "label": "Button link (unused)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Champagne Story",
      "blocks": [
        { "type": "chapter" },
        { "type": "chapter" }
      ]
    }
  ]
}
{% endschema %}
