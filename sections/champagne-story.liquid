{% comment %}
  Champagne de Lossy — Image band + heading/text (reference "Where We Belong")
  rev: fixed-image-v2 (position:fixed, sized to column)
  A row of images (side by side) whose backgrounds are FIXED while you scroll
  (position:fixed clipped per panel — robust equivalent of background-attachment:
  fixed, works on iOS too), with a centered heading + paragraph above or below.
  Block field ids kept (image / heading / body …) for backward compatibility.
{% endcomment %}

{%- assign content_first = false -%}
{%- if section.settings.content_position == 'top' -%}{%- assign content_first = true -%}{%- endif -%}

{%- capture cdl_text -%}
  {%- if section.settings.heading != blank or section.settings.intro != blank -%}
    <div class="page-width cdl-story__intro cdl-story__intro--{{ section.settings.content_position }}">
      {%- if section.settings.heading != blank -%}
        <h2 class="cdl-story__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <div class="cdl-story__intro-body">{{ section.settings.intro }}</div>
      {%- endif -%}
      {%- if section.settings.explore_text != blank -%}
        <a class="cdl-story__explore" href="{{ section.settings.explore_link | default: '#' }}">{{ section.settings.explore_text }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endcapture -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="cdl-story color-{{ section.settings.color_scheme }} section section--full-width spacing-style"
  style="{% render 'spacing-padding', settings: section.settings %} --cols: {{ section.settings.columns }}; --panel-h: {{ section.settings.panel_height }}px; --gap: {{ section.settings.image_gap }}px;"
>
  {%- if content_first -%}{{ cdl_text }}{%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="page-width">
    <div class="cdl-story__panels">
      {%- for block in section.blocks -%}
        <div
          class="cdl-story__panel{% if block.settings.image == blank %} cdl-story__panel--empty{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <div class="cdl-story__panel-bg" style="background-image: url('{{ block.settings.image | image_url: width: 2000 }}');"></div>
          {%- else -%}
            <span class="cdl-monogram" aria-hidden="true">DL</span>
          {%- endif -%}

          {%- if section.settings.show_panel_text and block.settings.heading != blank -%}
            <div class="cdl-story__panel-text">
              {%- if block.settings.eyebrow != blank -%}<p class="cdl-story__panel-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
              <h3 class="cdl-story__panel-title">{{ block.settings.heading }}</h3>
              {%- if block.settings.body != blank -%}<div class="cdl-story__panel-body">{{ block.settings.body }}</div>{%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    </div>
  {%- endif -%}

  {%- unless content_first -%}{{ cdl_text }}{%- endunless -%}
</section>

{% stylesheet %}
  .cdl-story { --cdl-gold: #b08d57; }

  /* ── Heading / text block ── */
  .cdl-story__intro {
    text-align: center;
    max-width: 64rem;
    margin-inline: auto;
  }
  .cdl-story__intro--top { padding-bottom: clamp(2.5rem, 5vw, 4.5rem); }
  .cdl-story__intro--bottom { padding-top: clamp(2.5rem, 5vw, 4.5rem); }

  .cdl-story__title {
    font-family: var(--font-heading--family);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    line-height: 1.06;
    letter-spacing: 0.02em;
    margin: 0 0 1.4rem;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  .cdl-story__intro-body {
    max-width: 44rem;
    margin: 0 auto;
    font-family: var(--font-body--family);
    font-size: clamp(0.98rem, 1.1vw, 1.08rem);
    line-height: 1.85;
    color: var(--color-foreground);
    opacity: 0.85;
  }
  .cdl-story__intro-body p { margin: 0 0 1rem; }
  .cdl-story__intro-body p:last-child { margin-bottom: 0; }

  .cdl-story__explore {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: var(--font-subheading--family);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--cdl-gold);
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--cdl-gold);
    transition: opacity 0.3s ease, letter-spacing 0.3s ease;
  }
  .cdl-story__explore:hover { opacity: 0.75; letter-spacing: 0.3em; }

  /* ── Image band — fixed backgrounds, side by side ── */
  .cdl-story__panels {
    display: grid;
    grid-template-columns: repeat(var(--cols, 2), 1fr);
    gap: var(--gap, 10px);
  }

  .cdl-story__panel {
    position: relative;
    min-height: var(--panel-h, 640px);
    display: grid;
    place-items: center;
    overflow: hidden;
    /* clip-path clips the position:fixed background to this panel */
    clip-path: inset(0);
  }

  /* The image is fixed to the viewport (it does NOT move while scrolling) and
     framed to the panel's COLUMN width (no zoom). JS sets left/width to match
     the column; height covers the viewport so it fills the panel as it passes. */
  .cdl-story__panel-bg {
    position: fixed;
    top: 0;
    height: 100vh;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    z-index: 0;
  }

  .cdl-story__panel > .cdl-story__panel-text,
  .cdl-story__panel > .cdl-monogram { position: relative; z-index: 1; }

  .cdl-story__panel--empty {
    background: linear-gradient(150deg, #f6efe2 0%, #e7d8bf 100%);
    border: 1px solid rgba(176, 141, 87, 0.3);
  }

  .cdl-monogram {
    font-family: var(--font-heading--family);
    font-size: clamp(3rem, 6vw, 5.5rem);
    letter-spacing: 0.1em;
    color: rgba(154, 118, 66, 0.4);
  }

  /* Optional caption overlay */
  .cdl-story__panel-text {
    display: grid;
    align-content: center;
    justify-items: center;
    text-align: center;
    padding: 2rem;
    color: #fff;
    text-shadow: 0 1px 24px rgba(0, 0, 0, 0.45);
  }
  .cdl-story__panel:not(.cdl-story__panel--empty):has(.cdl-story__panel-text)::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(20, 16, 12, 0.3);
    z-index: 0;
  }
  .cdl-story__panel-eyebrow {
    font-family: var(--font-subheading--family);
    font-size: 0.7rem; letter-spacing: 0.26em; text-transform: uppercase;
    color: #fff; opacity: 0.85; margin: 0 0 0.75rem;
  }
  .cdl-story__panel-title {
    font-family: var(--font-heading--family);
    font-weight: 400; text-transform: uppercase;
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    margin: 0 0 0.75rem; color: #fff;
  }
  .cdl-story__panel-body {
    font-family: var(--font-body--family);
    font-size: 0.95rem; line-height: 1.7; color: #fff; opacity: 0.92;
    max-width: 30rem;
  }

  /* Small screens: stack + normal (non-fixed) backgrounds to avoid touch jank */
  @media screen and (max-width: 749px) {
    .cdl-story__panels { grid-template-columns: 1fr; }
    .cdl-story__panel { clip-path: none; min-height: clamp(320px, 70vw, 520px); }
    /* normal (non-fixed) background on mobile */
    .cdl-story__panel-bg { position: absolute; inset: 0; height: 100%; }
  }
{% endstylesheet %}

<script>
  (function () {
    if (window.__cdlStoryFixed) return;
    window.__cdlStoryFixed = true;
    var mq = window.matchMedia ? window.matchMedia('(max-width: 749px)') : null;

    // Position each fixed background to match its column (left + width).
    // No scroll handler — the image stays truly fixed; only layout changes matter.
    function layout() {
      var isMobile = mq && mq.matches;
      var bgs = document.querySelectorAll('.cdl-story__panel-bg');
      for (var i = 0; i < bgs.length; i++) {
        var bg = bgs[i];
        if (isMobile) { bg.style.left = ''; bg.style.width = ''; continue; }
        var rect = bg.parentElement.getBoundingClientRect();
        bg.style.left = rect.left + 'px';
        bg.style.width = rect.width + 'px';
      }
    }

    window.addEventListener('resize', layout, { passive: true });
    window.addEventListener('orientationchange', layout);
    window.addEventListener('load', layout);
    document.addEventListener('DOMContentLoaded', layout);
    // a couple of delayed passes in case fonts/images shift the layout
    setTimeout(layout, 300);
    setTimeout(layout, 1000);
    layout();
  })();
</script>

{% schema %}
{
  "name": "Champagne Story",
  "tag": "section",
  "class": "section-cdl-story",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Where We Belong" },
    { "type": "richtext", "id": "intro", "label": "Paragraph", "default": "<p>Our home is more than a prestigious château. For generations, it has been a place of warm gatherings where celebration is our way of life. A lunch in the garden, a toast in the living room, an evening in the dining room — people come together to share a moment.</p>" },
    { "type": "text", "id": "explore_text", "label": "Link label (optional)" },
    { "type": "url", "id": "explore_link", "label": "Link" },
    {
      "type": "select",
      "id": "content_position",
      "label": "Text position",
      "options": [
        { "value": "top", "label": "Above images" },
        { "value": "bottom", "label": "Below images" }
      ],
      "default": "top"
    },
    { "type": "header", "content": "Image band (fixed backgrounds)" },
    { "type": "range", "id": "columns", "label": "Images per row", "min": 1, "max": 3, "step": 1, "default": 2 },
    { "type": "range", "id": "panel_height", "label": "Image height", "min": 320, "max": 1000, "step": 10, "unit": "px", "default": 640 },
    { "type": "range", "id": "image_gap", "label": "Gap between images", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 10 },
    { "type": "checkbox", "id": "show_panel_text", "label": "Show caption text over images", "default": false },
    { "type": "header", "content": "Appearance" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select",
          "id": "media_position",
          "label": "Image position (unused)",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        { "type": "text", "id": "eyebrow", "label": "Caption eyebrow" },
        { "type": "text", "id": "heading", "label": "Caption heading" },
        { "type": "richtext", "id": "body", "label": "Caption text" },
        { "type": "text", "id": "button_text", "label": "Button label (unused)" },
        { "type": "url", "id": "button_link", "label": "Button link (unused)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Champagne Story",
      "blocks": [
        { "type": "chapter" },
        { "type": "chapter" }
      ]
    }
  ]
}
{% endschema %}
