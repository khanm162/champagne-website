{% comment %}
PointAndFlow Treatment Categories Section
Premium luxury editorial — refined spa aesthetic
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

<section class="pf-treatment-categories" id="pf-treatment-{{ section.id }}">

  <!-- Grain overlay for texture depth -->
  <div class="pf-grain" aria-hidden="true"></div>

  <div class="pf-treatment-inner page-width">

    <header class="pf-treatment-header">

      {% if section.settings.subheading != blank %}
        <div class="pf-eyebrow">
          <span class="pf-eyebrow-line"></span>
          <p class="pf-treatment-subheading">{{ section.settings.subheading }}</p>
          <span class="pf-eyebrow-line"></span>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="pf-treatment-heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="pf-treatment-description">
          {{ section.settings.description }}
        </div>
      {% endif %}

    </header>

    <div class="pf-treatment-grid">

      {% for block in section.blocks %}
        <a
          href="{{ block.settings.card_link }}"
          class="pf-treatment-card pf-card-{{ forloop.index }} reveal-card"
          {{ block.shopify_attributes }}
        >

          {% if block.settings.image != blank %}
            <div class="pf-treatment-image">
              <img
                src="{{ block.settings.image | image_url: width: 1400 }}"
                alt="{{ block.settings.title }}"
                loading="lazy"
              >
            </div>
          {% else %}
            <div class="pf-treatment-image pf-treatment-image--placeholder"></div>
          {% endif %}

          <!-- Layered overlays for depth -->
          <div class="pf-overlay-base"></div>
          <div class="pf-overlay-vignette"></div>

          <div class="pf-treatment-content">

          
            <h3 class="pf-card-title">{{ block.settings.title }}</h3>

            <div class="pf-card-divider" aria-hidden="true"></div>

            {% if block.settings.text != blank %}
              <p class="pf-card-text">{{ block.settings.text }}</p>
            {% endif %}

            <span class="pf-treatment-btn">
              <span class="pf-btn-label">Explore</span>
              <svg class="pf-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>

          </div>

        </a>
      {% endfor %}

    </div>

  </div>
</section>

<style>

/* ─── Tokens ─── */
#pf-treatment-{{ section.id }} {
  --pf-bg:         #EDE8E1;
  --pf-dark:       #1C1A17;
  --pf-gold:       #B89A6A;
  --pf-gold-light: #D4B896;
  --pf-sage:       #5A7260;
  --pf-white:      #FFFFFF;
  --pf-text-muted: #888079;
  --pf-radius:     24px;
  --pf-gap:        12px;
  --pf-font-serif: 'Cormorant Garamond', Georgia, serif;
  --pf-font-sans:  'Jost', sans-serif;
  --pf-ease-expo:  cubic-bezier(0.16, 1, 0.3, 1);
}

/* ─── Section Shell ─── */
.pf-treatment-categories {
  position: relative;
  padding: 130px 40px 150px;
  background-color: var(--pf-bg);
  overflow: hidden;
}

/* Grain texture overlay */
.pf-grain {
  position: absolute;
  inset: -50%;
  width: 200%;
  height: 200%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
  opacity: 0.022;
  pointer-events: none;
  animation: pf-grain-shift 8s steps(10) infinite;
}

@keyframes pf-grain-shift {
  0%, 100% { transform: translate(0, 0); }
  10%       { transform: translate(-1%, -1%); }
  20%       { transform: translate(1%, 0); }
  30%       { transform: translate(-1%, 1%); }
  40%       { transform: translate(0, -1%); }
  50%       { transform: translate(1%, 1%); }
  60%       { transform: translate(-1%, 0); }
  70%       { transform: translate(0, 1%); }
  80%       { transform: translate(1%, -1%); }
  90%       { transform: translate(-1%, 1%); }
}

.pf-treatment-inner {
  position: relative;
  z-index: 1;
}

/* ─── Header ─── */
.pf-treatment-header {
  text-align: center;
  margin-bottom: 80px;
}

.pf-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  margin-bottom: 22px;
}

.pf-eyebrow-line {
  display: block;
  width: 40px;
  height: 1px;
  background: var(--pf-gold);
  opacity: 0.7;
}

.pf-treatment-subheading {
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--pf-gold);
  margin: 0;
}

.pf-treatment-heading {
  font-family: var(--pf-font-serif);
  font-weight: 300;
  font-size: 72px;
  line-height: 1.05;
  letter-spacing: -0.5px;
  color: var(--pf-dark);
  margin: 0 0 30px;
}

.pf-treatment-heading em {
  font-style: italic;
  color: var(--pf-gold);
}

.pf-treatment-description {
  font-family: var(--pf-font-sans);
  font-weight: 300;
  max-width: 680px;
  margin: 0 auto;
  color: var(--pf-text-muted);
  font-size: 16px;
  line-height: 1.9;
}

/* ─── Grid ─── */
.pf-treatment-grid {
  display: grid;
  gap: var(--pf-gap);
  grid-template-columns: repeat(12, 1fr);
  grid-template-rows: auto;
}

/* Asymmetric editorial layout */
.pf-card-1 { grid-column: 1 / 8;  grid-row: 1; min-height: 600px; }
.pf-card-2 { grid-column: 8 / 13; grid-row: 1; min-height: 600px; }
.pf-card-3 { grid-column: 1 / 5;  grid-row: 2; min-height: 520px; }
.pf-card-4 { grid-column: 5 / 13; grid-row: 2; min-height: 520px; }
.pf-card-5 { grid-column: 1 / 6;  grid-row: 3; min-height: 520px; }
.pf-card-6 { grid-column: 6 / 13; grid-row: 3; min-height: 520px; }

/* ─── Card Base ─── */
.pf-treatment-card {
  position: relative;
  border-radius: var(--pf-radius);
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  text-decoration: none;
  cursor: pointer;

  /* Reveal state */
  opacity: 0;
  transform: translateY(48px) scale(0.98);
  transition:
    opacity 0.9s var(--pf-ease-expo),
    transform 0.9s var(--pf-ease-expo),
    box-shadow 0.5s ease;
}

.pf-treatment-card.show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.pf-treatment-card:hover {
  box-shadow:
    0 30px 80px rgba(0,0,0,0.22),
    0 4px 20px rgba(0,0,0,0.12);
}

/* ─── Image ─── */
.pf-treatment-image {
  position: absolute;
  inset: 0;
}

.pf-treatment-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 1.4s var(--pf-ease-expo);
  will-change: transform;
}

.pf-treatment-card:hover .pf-treatment-image img {
  transform: scale(1.07);
}

.pf-treatment-image--placeholder {
  background: linear-gradient(135deg, #cfc8bc, #b8b0a4);
}

/* ─── Overlays ─── */
.pf-overlay-base {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(18, 15, 10, 0.88) 0%,
    rgba(18, 15, 10, 0.45) 40%,
    rgba(18, 15, 10, 0.05) 70%,
    transparent 100%
  );
  transition: opacity 0.5s ease;
}

.pf-overlay-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse at 50% 120%,
    rgba(184, 154, 106, 0.12) 0%,
    transparent 70%
  );
  pointer-events: none;
}

/* ─── Card Content ─── */
.pf-treatment-content {
  position: relative;
  z-index: 2;
  padding: 38px 40px;
  width: 100%;
}

.pf-card-number {
  font-family: var(--pf-font-serif);
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 3px;
  color: var(--pf-gold);
  margin-bottom: 14px;
  opacity: 0.85;
}

.pf-card-title {
  font-family: var(--pf-font-serif);
  font-weight: 300;
  font-size: 42px;
  line-height: 1.08;
  color: var(--pf-white);
  margin: 0 0 20px;
  letter-spacing: -0.2px;
}

.pf-card-divider {
  width: 32px;
  height: 1px;
  background: var(--pf-gold);
  margin-bottom: 18px;
  transition: width 0.4s var(--pf-ease-expo);
}

.pf-treatment-card:hover .pf-card-divider {
  width: 56px;
}

.pf-card-text {
  font-family: var(--pf-font-sans);
  font-weight: 300;
  font-size: 14px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.72);
  margin: 0 0 28px;
  max-width: 88%;

  /* Hidden until hover for a cleaner resting state */
  opacity: 0;
  transform: translateY(8px);
  transition:
    opacity 0.4s ease,
    transform 0.4s var(--pf-ease-expo);
}

.pf-treatment-card:hover .pf-card-text {
  opacity: 1;
  transform: translateY(0);
}

/* ─── Button ─── */
.pf-treatment-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--pf-white);
  padding: 12px 22px 12px 24px;
  border-radius: 100px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  transition: all 0.35s ease;
}

.pf-btn-arrow {
  transition: transform 0.35s var(--pf-ease-expo);
}

.pf-treatment-card:hover .pf-treatment-btn {
  background: var(--pf-gold);
  border-color: var(--pf-gold);
  color: var(--pf-dark);
}

.pf-treatment-card:hover .pf-btn-arrow {
  transform: translateX(4px);
}

/* ─── Staggered reveal delays ─── */
.pf-card-1 { transition-delay: 0ms; }
.pf-card-2 { transition-delay: 120ms; }
.pf-card-3 { transition-delay: 240ms; }
.pf-card-4 { transition-delay: 160ms; }
.pf-card-5 { transition-delay: 280ms; }
.pf-card-6 { transition-delay: 200ms; }

/* ─── Tablet ─── */
@media (max-width: 1100px) {
  .pf-treatment-heading { font-size: 56px; }

  .pf-card-1 { grid-column: 1 / 8;  min-height: 500px; }
  .pf-card-2 { grid-column: 8 / 13; min-height: 500px; }
  .pf-card-3 { grid-column: 1 / 7;  min-height: 440px; }
  .pf-card-4 { grid-column: 7 / 13; min-height: 440px; }
  .pf-card-5 { grid-column: 1 / 7;  min-height: 440px; }
  .pf-card-6 { grid-column: 7 / 13; min-height: 440px; }

  .pf-card-text { opacity: 1; transform: none; }
}

/* ─── Mobile ─── */
@media (max-width: 768px) {
  .pf-treatment-categories {
    padding: 80px 0 100px;
  }

  .pf-treatment-inner {
    padding: 0 20px;
  }

  .pf-treatment-header {
    margin-bottom: 50px;
    padding: 0 4px;
  }

  .pf-treatment-heading {
    font-size: 44px;
  }

  .pf-treatment-grid {
    display: flex;
    flex-direction: row;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0 20px 20px;
    margin: 0 -20px;
    gap: 10px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .pf-treatment-grid::-webkit-scrollbar { display: none; }

  .pf-treatment-card {
    min-width: 82vw;
    max-width: 82vw;
    min-height: 480px;
    flex-shrink: 0;
    scroll-snap-align: start;
    /* Reset grid positioning */
    grid-column: unset !important;
    grid-row: unset !important;
  }

  .pf-card-title { font-size: 34px; }

  .pf-card-text {
    opacity: 1;
    transform: none;
  }

  .pf-treatment-content {
    padding: 28px 28px;
  }

  /* Mobile scroll indicator dots */
  .pf-scroll-hint {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 24px;
  }

  .pf-scroll-hint span {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--pf-gold);
    opacity: 0.3;
  }

  .pf-scroll-hint span:first-child {
    opacity: 1;
  }
}

@media (max-width: 480px) {
  .pf-treatment-card {
    min-width: 88vw;
    max-width: 88vw;
  }
}

</style>

<script>
(function() {
  document.addEventListener("DOMContentLoaded", function () {

    const section = document.getElementById('pf-treatment-{{ section.id }}');
    if (!section) return;

    const cards = section.querySelectorAll('.reveal-card');
    const isMobile = window.innerWidth < 768;

    if (isMobile) {
      // On mobile: show all immediately, they're in a scroll container
      cards.forEach(card => card.classList.add('show'));

      // Add scroll hint dots below grid
      const grid = section.querySelector('.pf-treatment-grid');
      if (grid && cards.length > 1) {
        const hint = document.createElement('div');
        hint.className = 'pf-scroll-hint';
        cards.forEach((_, i) => {
          const dot = document.createElement('span');
          hint.appendChild(dot);
        });
        grid.parentNode.insertBefore(hint, grid.nextSibling);

        // Update active dot on scroll
        const dots = hint.querySelectorAll('span');
        grid.addEventListener('scroll', function () {
          const scrollLeft = grid.scrollLeft;
          const cardWidth = cards[0] ? cards[0].offsetWidth + 10 : grid.offsetWidth;
          const activeIndex = Math.round(scrollLeft / cardWidth);
          dots.forEach((dot, i) => {
            dot.style.opacity = i === activeIndex ? '1' : '0.3';
          });
        }, { passive: true });
      }

      return;
    }

    // Desktop: staggered scroll-triggered reveal
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('show');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach(card => observer.observe(card));

  });
})();
</script>

{% schema %}
{
  "name": "Treatment Categories",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Specialized Wellness"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Our Treatments"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Treatment Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "card_link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PointAndFlow Treatment Categories"
    }
  ]
}
{% endschema %}
