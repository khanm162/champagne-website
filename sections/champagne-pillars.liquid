{% comment %}
  Champagne de Lossy — Brand pillars
  Icon + title + text strip. Icon chosen from a curated champagne set.
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<section
  class="cdl-pillars color-{{ section.settings.color_scheme }} section section--{{ section.settings.section_width }}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="cdl-pillars__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="cdl-pillars__grid">
      {%- for block in section.blocks -%}
        <div class="cdl-pillar" {{ block.shopify_attributes }}>
          <span class="cdl-pillar__icon">
            {%- case block.settings.icon -%}
              {%- when 'vineyard' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="14" r="5" stroke="currentColor" stroke-width="1.4"/><circle cx="16" cy="24" r="5" stroke="currentColor" stroke-width="1.4"/><circle cx="32" cy="24" r="5" stroke="currentColor" stroke-width="1.4"/><circle cx="24" cy="33" r="5" stroke="currentColor" stroke-width="1.4"/><path d="M24 9V3M24 3c4 0 7-1 9-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              {%- when 'bottle' -%}
                <svg viewBox="0 0 48 48" fill="none"><path d="M24 4c-1.4 0-2 .8-2 2v10c0 4-5 6-5 14v12c0 2 1 3 3 3h8c2 0 3-1 3-3V30c0-8-5-10-5-14V6c0-1.2-.6-2-2-2z" stroke="currentColor" stroke-width="1.4"/><rect x="19" y="30" width="10" height="9" rx="1" stroke="currentColor" stroke-width="1.1"/></svg>
              {%- when 'ship' -%}
                <svg viewBox="0 0 48 48" fill="none"><path d="M6 30l3 9c.3 1 1.2 1.6 2.2 1.6h25.6c1 0 1.9-.6 2.2-1.6l3-9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M9 30V14h22l8 8v8" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M31 14v8h8" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
              {%- when 'age' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="19" stroke="currentColor" stroke-width="1.4"/><text x="24" y="30" text-anchor="middle" font-size="16" font-family="serif" fill="currentColor">21+</text></svg>
              {%- when 'leaf' -%}
                <svg viewBox="0 0 48 48" fill="none"><path d="M12 36C12 20 28 12 38 12c0 16-10 24-26 24z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M16 32c8-4 14-10 18-16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              {%- else -%}
                <svg viewBox="0 0 48 48" fill="none"><path d="M16 6h16l-1 14a7 7 0 01-14 0L16 6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M24 27v9M18 42h12M19 42a5 5 0 0110 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
            {%- endcase -%}
          </span>
          {%- if block.settings.title != blank -%}
            <h3 class="cdl-pillar__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="cdl-pillar__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .cdl-pillars { --cdl-gold: #b08d57; text-align: center; }

  .cdl-pillars__title {
    font-family: var(--font-heading--family);
    font-weight: 400;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    margin: 0 0 clamp(2rem, 4vw, 3.5rem);
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  .cdl-pillars__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
  }

  .cdl-pillar { padding: 0 0.5rem; }

  .cdl-pillar__icon { display: inline-flex; color: var(--cdl-gold); }
  .cdl-pillar__icon svg { width: 46px; height: 46px; }

  .cdl-pillar__title {
    font-family: var(--font-heading--family);
    font-weight: 400;
    font-size: 1.25rem;
    margin: 1rem 0 0.55rem;
    color: var(--color-foreground-heading, var(--color-foreground));
  }

  .cdl-pillar__text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.74;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .cdl-pillars__grid { grid-template-columns: repeat(2, 1fr); gap: 2.25rem 1.25rem; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Champagne Pillars",
  "tag": "section",
  "class": "section-cdl-pillars",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "vineyard", "label": "Vineyard / grapes" },
            { "value": "bottle", "label": "Bottle" },
            { "value": "ship", "label": "Shipping" },
            { "value": "age", "label": "21+" },
            { "value": "leaf", "label": "Sustainability" },
            { "value": "glass", "label": "Champagne glass" }
          ],
          "default": "bottle"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Estate Bottled" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Grown, vinified and bottled at the estate in Rilly-la-Montagne." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Champagne Pillars",
      "blocks": [
        { "type": "pillar", "settings": { "icon": "vineyard" } },
        { "type": "pillar", "settings": { "icon": "bottle" } },
        { "type": "pillar", "settings": { "icon": "ship" } },
        { "type": "pillar", "settings": { "icon": "age" } }
      ]
    }
  ]
}
{% endschema %}
