{% comment %}
PointAndFlow Custom Slideshow
Premium luxury editorial — refined spa aesthetic
Matches pf-treatment-categories design system
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

<section
  class="pf-slideshow"
  id="pf-slideshow-{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.slide_speed }}"
  aria-label="Featured slideshow"
>

  <!-- Grain overlay -->
  <div class="pf-ss-grain" aria-hidden="true"></div>

  <!-- Slides -->
  <div class="pf-ss-track">
    {% for block in section.blocks %}
      <div
        class="pf-slide {% if forloop.first %}is-active{% endif %}"
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
        aria-hidden="{% unless forloop.first %}true{% endunless %}"
      >

        <!-- Background image with Ken Burns -->
        {% if block.settings.slide_image != blank %}
          <div class="pf-slide-bg {% cycle 'kb-left', 'kb-right' %}">
            <img
              src="{{ block.settings.slide_image | image_url: width: 2400 }}"
              alt="{{ block.settings.heading }}"
              {% unless forloop.first %}loading="lazy"{% endunless %}
              draggable="false"
            >
          </div>
        {% else %}
          <div class="pf-slide-bg pf-slide-bg--empty"></div>
        {% endif %}

        <!-- Layered overlays -->
        <div class="pf-ss-overlay-dark" aria-hidden="true"></div>
        <div class="pf-ss-overlay-vignette" aria-hidden="true"></div>
        <div class="pf-ss-overlay-bottom" aria-hidden="true"></div>

        <!-- Content -->
        <div class="pf-ss-content page-width">
          <div class="pf-ss-content-inner">

            {% if block.settings.subheading != blank %}
              <div class="pf-ss-eyebrow ss-anim ss-anim--1">
                <span class="pf-ss-eyebrow-line" aria-hidden="true"></span>
                <p>{{ block.settings.subheading }}</p>
              </div>
            {% endif %}

            {% if block.settings.heading != blank %}
              <h1 class="pf-ss-heading">
                {% assign words = block.settings.heading | split: ' ' %}
                {% for word in words %}
                  <span class="pf-word-wrap ss-anim" style="--word-i: {{ forloop.index }};">
                    <span class="pf-word">{{ word }}</span>
                  </span>
                  {%- unless forloop.last %}&nbsp;{% endunless -%}
                {% endfor %}
              </h1>
            {% endif %}

            {% if block.settings.description != blank %}
              <div class="pf-ss-description ss-anim ss-anim--desc">
                {{ block.settings.description }}
              </div>
            {% endif %}

            {% if block.settings.button_text != blank or block.settings.button_text_2 != blank %}
              <div class="pf-ss-buttons ss-anim ss-anim--btns">

                {% if block.settings.button_text != blank %}
                  <a href="{{ block.settings.button_link }}" class="pf-ss-btn pf-ss-btn--primary">
                    <span>{{ block.settings.button_text }}</span>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                {% endif %}

                {% if block.settings.button_text_2 != blank %}
                  <a href="{{ block.settings.button_link_2 }}" class="pf-ss-btn pf-ss-btn--secondary">
                    <span>{{ block.settings.button_text_2 }}</span>
                  </a>
                {% endif %}

              </div>
            {% endif %}

          </div>
        </div>

      </div>
    {% endfor %}
  </div>

  <!-- UI Chrome -->
  {% if section.blocks.size > 1 %}

    <!-- Slide counter -->
    <div class="pf-ss-counter" aria-hidden="true">
      <span class="pf-ss-counter-current">01</span>
      <span class="pf-ss-counter-sep">/</span>
      <span class="pf-ss-counter-total">0{{ section.blocks.size }}</span>
    </div>

    <!-- Progress bar -->
    <div class="pf-ss-progress" aria-hidden="true">
      <div class="pf-ss-progress-fill"></div>
    </div>

    <!-- Navigation arrows -->
    <button class="pf-ss-nav pf-ss-nav--prev" aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <button class="pf-ss-nav pf-ss-nav--next" aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Dot navigation -->
    <nav class="pf-ss-dots" aria-label="Slide navigation">
      {% for block in section.blocks %}
        <button
          class="pf-ss-dot {% if forloop.first %}is-active{% endif %}"
          data-slide="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {% endfor %}
    </nav>

  {% endif %}

  <!-- Scroll cue -->
  <div class="pf-ss-scroll-cue" aria-hidden="true">
    <span class="pf-ss-scroll-line"></span>
    <span class="pf-ss-scroll-label">Scroll</span>
  </div>

</section>

<style>

/* ─── Tokens ─── */
#pf-slideshow-{{ section.id }} {
  --pf-gold:        #B89A6A;
  --pf-gold-light:  #D4B896;
  --pf-dark:        #1C1A17;
  --pf-white:       #FFFFFF;
  --pf-font-serif:  'Cormorant Garamond', Georgia, serif;
  --pf-font-sans:   'Jost', sans-serif;
  --pf-ease-expo:   cubic-bezier(0.16, 1, 0.3, 1);
  --pf-ease-out:    cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --pf-speed:       {{ section.settings.slide_speed }}s;
}

/* ─── Shell ─── */
.pf-slideshow {
  position: relative;
  height: 95vh;
  min-height: 600px;
  overflow: hidden;
  background: var(--pf-dark);
}

/* Grain */
.pf-ss-grain {
  position: absolute;
  inset: -50%;
  width: 200%;
  height: 200%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.028;
  pointer-events: none;
  z-index: 10;
  animation: pf-grain 8s steps(10) infinite;
}

@keyframes pf-grain {
  0%,100% { transform: translate(0,0) }
  10%     { transform: translate(-1%,-1%) }
  20%     { transform: translate(1%,0) }
  30%     { transform: translate(-1%,1%) }
  40%     { transform: translate(0,-1%) }
  50%     { transform: translate(1%,1%) }
  60%     { transform: translate(-1%,0) }
  70%     { transform: translate(0,1%) }
  80%     { transform: translate(1%,-1%) }
  90%     { transform: translate(-1%,1%) }
}

/* ─── Track + Slides ─── */
.pf-ss-track {
  position: absolute;
  inset: 0;
}

.pf-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition:
    opacity 1.4s var(--pf-ease-out),
    visibility 1.4s;
}

.pf-slide.is-active {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

/* ─── Background / Ken Burns ─── */
.pf-slide-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.pf-slide-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform-origin: center center;
  will-change: transform;
}

/* Ken Burns: only runs while slide is active */
.pf-slide.is-active .pf-slide-bg.kb-left img {
  animation: kb-left var(--pf-speed) linear forwards;
}

.pf-slide.is-active .pf-slide-bg.kb-right img {
  animation: kb-right var(--pf-speed) linear forwards;
}

@keyframes kb-left {
  from { transform: scale(1.0) translate(0, 0); }
  to   { transform: scale(1.12) translate(-24px, -8px); }
}

@keyframes kb-right {
  from { transform: scale(1.0) translate(0, 0); }
  to   { transform: scale(1.12) translate(24px, -8px); }
}

.pf-slide-bg--empty {
  background: linear-gradient(135deg, #2a2520, #1a1714);
}

/* ─── Overlays ─── */
.pf-ss-overlay-dark {
  position: absolute;
  inset: 0;
  background: rgba(14, 12, 9, 0.42);
}

.pf-ss-overlay-vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 70% 50%, transparent 30%, rgba(10, 8, 6, 0.55) 100%);
}

.pf-ss-overlay-bottom {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 280px;
  background: linear-gradient(to top, rgba(10, 8, 6, 0.65), transparent);
}

/* ─── Content ─── */
.pf-ss-content {
  position: relative;
  z-index: 4;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 80px;
}

.pf-ss-content-inner {
  max-width: 720px;
}

/* Eyebrow */
.pf-ss-eyebrow {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 24px;
}

.pf-ss-eyebrow-line {
  display: block;
  width: 36px;
  height: 1px;
  background: var(--pf-gold);
  flex-shrink: 0;
}

.pf-ss-eyebrow p {
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--pf-gold);
  margin: 0;
}

/* Heading — word-by-word reveal */
.pf-ss-heading {
  font-family: var(--pf-font-serif);
  font-weight: 300;
  font-size: clamp(52px, 7vw, 96px);
  line-height: 1.0;
  letter-spacing: -0.5px;
  color: var(--pf-white);
  margin: 0 0 28px;
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.pf-word-wrap {
  display: inline-block;
  overflow: hidden;
  vertical-align: top;
}

.pf-word {
  display: inline-block;
  transform: translateY(110%);
  transition: transform 0s; /* reset between slides */
}

/* Description */
.pf-ss-description {
  font-family: var(--pf-font-sans);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.70);
  max-width: 540px;
  margin: 0 0 36px;
}

/* Buttons */
.pf-ss-buttons {
  display: flex;
  align-items: center;
  gap: 16px;
}

.pf-ss-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 26px 14px 28px;
  border-radius: 100px;
  transition: all 0.35s ease;
}

.pf-ss-btn svg {
  transition: transform 0.35s var(--pf-ease-expo);
  flex-shrink: 0;
}

.pf-ss-btn:hover svg {
  transform: translateX(4px);
}

.pf-ss-btn--primary {
  background: var(--pf-gold);
  color: var(--pf-dark);
  border: 1px solid var(--pf-gold);
}

.pf-ss-btn--primary:hover {
  background: var(--pf-gold-light);
  border-color: var(--pf-gold-light);
}

.pf-ss-btn--secondary {
  background: rgba(255, 255, 255, 0.08);
  color: var(--pf-white);
  border: 1px solid rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.pf-ss-btn--secondary:hover {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.5);
}

/* ─── Text reveal animations ─── */

/* Generic slide-in items (eyebrow, desc, buttons) */
.ss-anim {
  opacity: 0;
  transform: translateY(28px);
}

.pf-slide.is-active .ss-anim {
  animation: ss-fade-up 0.9s var(--pf-ease-expo) forwards;
}

.pf-slide.is-active .ss-anim--1     { animation-delay: 0.2s; }
.pf-slide.is-active .ss-anim--desc  { animation-delay: 0.85s; }
.pf-slide.is-active .ss-anim--btns  { animation-delay: 1.05s; }

@keyframes ss-fade-up {
  to { opacity: 1; transform: translateY(0); }
}

/* Word-by-word heading reveal */
.pf-slide.is-active .pf-word {
  animation: pf-word-in 0.75s var(--pf-ease-expo) forwards;
}

/* stagger per word index */
{% for block in section.blocks %}
  {% assign words_count = block.settings.heading | split: ' ' | size %}
  {% for i in (1..words_count) %}
    .pf-slide[data-index="{{ forloop.parentloop.index0 }}"].is-active .pf-word-wrap:nth-child({{ forloop.index }}) .pf-word {
      animation-delay: {{ 0.35 | plus: forloop.index | times: 0.1 }}s;
    }
  {% endfor %}
{% endfor %}

@keyframes pf-word-in {
  to { transform: translateY(0); }
}

/* ─── Slide Counter ─── */
.pf-ss-counter {
  position: absolute;
  bottom: 52px;
  left: 80px;
  z-index: 8;
  display: flex;
  align-items: baseline;
  gap: 6px;
  font-family: var(--pf-font-sans);
  font-size: 12px;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 1px;
}

.pf-ss-counter-current {
  font-size: 22px;
  font-family: var(--pf-font-serif);
  font-weight: 300;
  color: var(--pf-white);
  line-height: 1;
}

.pf-ss-counter-sep {
  opacity: 0.4;
}

/* ─── Progress Bar ─── */
.pf-ss-progress {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: rgba(255, 255, 255, 0.12);
  z-index: 8;
}

.pf-ss-progress-fill {
  height: 100%;
  background: var(--pf-gold);
  width: 0%;
  transition: width 0.1s linear;
}

/* ─── Navigation Arrows ─── */
.pf-ss-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: var(--pf-white);
  cursor: pointer;
  transition: all 0.3s ease;
}

.pf-ss-nav:hover {
  background: var(--pf-gold);
  border-color: var(--pf-gold);
  color: var(--pf-dark);
}

.pf-ss-nav--prev { left: 32px; }
.pf-ss-nav--next { right: 32px; }

/* ─── Dot Navigation ─── */
.pf-ss-dots {
  position: absolute;
  bottom: 48px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 8;
  display: flex;
  gap: 10px;
}

.pf-ss-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.4);
  background: transparent;
  cursor: pointer;
  padding: 0;
  transition: all 0.35s ease;
}

.pf-ss-dot.is-active {
  background: var(--pf-gold);
  border-color: var(--pf-gold);
  transform: scale(1.4);
}

.pf-ss-dot:hover:not(.is-active) {
  border-color: rgba(255,255,255,0.8);
}

/* ─── Scroll Cue ─── */
.pf-ss-scroll-cue {
  position: absolute;
  right: 40px;
  bottom: 44px;
  z-index: 8;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.pf-ss-scroll-label {
  font-family: var(--pf-font-sans);
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.35);
  writing-mode: vertical-rl;
  text-orientation: mixed;
}

.pf-ss-scroll-line {
  display: block;
  width: 1px;
  height: 52px;
  background: linear-gradient(to bottom, var(--pf-gold), transparent);
  animation: scroll-pulse 2s ease-in-out infinite;
}

@keyframes scroll-pulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); transform-origin: top; }
  50%       { opacity: 1;   transform: scaleY(1.15); }
}

/* ─── Tablet ─── */
@media (max-width: 1100px) {
  .pf-ss-content {
    padding: 0 60px;
  }

  .pf-ss-counter { left: 60px; }
  .pf-ss-nav--prev { left: 20px; }
  .pf-ss-nav--next { right: 20px; }
  .pf-ss-scroll-cue { display: none; }
}

/* ─── Mobile ─── */
@media (max-width: 768px) {
  .pf-slideshow {
    height: 88vh;
    min-height: 560px;
  }

  .pf-ss-content {
    padding: 0 24px;
    align-items: flex-end;
    padding-bottom: 100px;
  }

  .pf-ss-content-inner {
    max-width: 100%;
    text-align: left;
  }

  .pf-ss-heading {
    font-size: clamp(42px, 11vw, 62px);
  }

  .pf-ss-description {
    font-size: 14px;
    max-width: 100%;
  }

  .pf-ss-buttons {
    flex-direction: column;
    align-items: flex-start;
  }

  .pf-ss-btn {
    width: 100%;
    justify-content: center;
  }

  .pf-ss-nav {
    display: none;
  }

  .pf-ss-counter {
    left: 24px;
    bottom: 64px;
  }

  .pf-ss-dots {
    bottom: 36px;
  }

  /* Touch swipe hint */
  .pf-ss-eyebrow {
    margin-bottom: 18px;
  }
}

</style>

<script>
(function () {
  document.addEventListener('DOMContentLoaded', function () {

    const section = document.getElementById('pf-slideshow-{{ section.id }}');
    if (!section) return;

    const slides     = section.querySelectorAll('.pf-slide');
    const dots       = section.querySelectorAll('.pf-ss-dot');
    const prevBtn    = section.querySelector('.pf-ss-nav--prev');
    const nextBtn    = section.querySelector('.pf-ss-nav--next');
    const counter    = section.querySelector('.pf-ss-counter-current');
    const progressFill = section.querySelector('.pf-ss-progress-fill');

    if (!slides.length) return;

    const TOTAL      = slides.length;
    const autoplay   = section.dataset.autoplay === 'true';
    const speedMs    = (parseInt(section.dataset.speed) || 5) * 1000;

    let current      = 0;
    let timer        = null;
    let progTimer    = null;
    let progStart    = null;

    // ── Helpers ──────────────────────────────
    function pad(n) {
      return n < 10 ? '0' + n : '' + n;
    }

    function resetWords(slide) {
      slide.querySelectorAll('.pf-word').forEach(w => {
        w.style.transition = 'none';
        w.style.transform  = 'translateY(110%)';
        // Force reflow
        w.offsetHeight;
        w.style.transition = '';
      });
      slide.querySelectorAll('.ss-anim').forEach(el => {
        el.style.animation = 'none';
        el.offsetHeight;
        el.style.animation = '';
      });
    }

    // ── Go to slide ──────────────────────────
    function goTo(index, direction) {
      if (index === current) return;

      const outSlide = slides[current];
      const inSlide  = slides[index];

      outSlide.classList.remove('is-active');
      outSlide.setAttribute('aria-hidden', 'true');

      // Reset incoming slide animations before activating
      resetWords(inSlide);

      current = index;
      inSlide.classList.add('is-active');
      inSlide.setAttribute('aria-hidden', 'false');

      // Update counter
      if (counter) counter.textContent = pad(current + 1);

      // Update dots
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === current);
      });

      // Restart progress
      if (autoplay) startProgress();
    }

    // ── Progress Bar ─────────────────────────
    function startProgress() {
      if (!progressFill) return;
      cancelAnimationFrame(progTimer);
      progStart = performance.now();

      function tick(now) {
        const elapsed = now - progStart;
        const pct = Math.min((elapsed / speedMs) * 100, 100);
        progressFill.style.width = pct + '%';
        if (pct < 100) {
          progTimer = requestAnimationFrame(tick);
        }
      }

      progTimer = requestAnimationFrame(tick);
    }

    // ── Autoplay ─────────────────────────────
    function startAutoplay() {
      clearInterval(timer);
      timer = setInterval(() => {
        goTo((current + 1) % TOTAL);
      }, speedMs);
    }

    function stopAutoplay() {
      clearInterval(timer);
      cancelAnimationFrame(progTimer);
      if (progressFill) progressFill.style.width = '0%';
    }

    // ── Button nav ───────────────────────────
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        stopAutoplay();
        goTo((current - 1 + TOTAL) % TOTAL);
        if (autoplay) startAutoplay();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        stopAutoplay();
        goTo((current + 1) % TOTAL);
        if (autoplay) startAutoplay();
      });
    }

    // ── Dot nav ──────────────────────────────
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        stopAutoplay();
        goTo(i);
        if (autoplay) startAutoplay();
      });
    });

    // ── Touch / swipe ────────────────────────
    let touchStartX = 0;
    let touchStartY = 0;

    section.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });

    section.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].screenX - touchStartX;
      const dy = e.changedTouches[0].screenY - touchStartY;
      if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
        stopAutoplay();
        goTo(dx < 0 ? (current + 1) % TOTAL : (current - 1 + TOTAL) % TOTAL);
        if (autoplay) startAutoplay();
      }
    }, { passive: true });

    // ── Keyboard nav ─────────────────────────
    section.addEventListener('keydown', e => {
      if (e.key === 'ArrowLeft')  { prevBtn && prevBtn.click(); }
      if (e.key === 'ArrowRight') { nextBtn && nextBtn.click(); }
    });

    // ── Init ─────────────────────────────────
    if (autoplay && TOTAL > 1) {
      startAutoplay();
      startProgress();
    }

  });
})();
</script>

