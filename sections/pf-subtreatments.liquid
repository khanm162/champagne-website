{% comment %}
PointAndFlow Sub Treatments Section
Luxury editorial treatment cards
Perfect for fertility / wellness pages
{% endcomment %}

<section class="pf-subtreatments-section">

  <div class="page-width">

    {% if section.settings.subheading != blank %}
      <p class="pf-subtreatments-subheading">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="pf-subtreatments-heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="pf-subtreatments-description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    <div class="pf-subtreatments-grid">

      {% for block in section.blocks %}

        <div class="pf-subtreatment-card reveal-treatment" {{ block.shopify_attributes }}>

          {% if block.settings.image != blank %}
            <div class="pf-subtreatment-image">
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.title }}"
              >
            </div>
          {% endif %}

          <div class="pf-subtreatment-content">

            <span class="pf-subtreatment-number">
              0{{ forloop.index }}
            </span>

            <h3>{{ block.settings.title }}</h3>

            <p>{{ block.settings.description }}</p>

            {% if block.settings.button_text != blank %}
              <a href="{{ block.settings.button_link }}" class="pf-subtreatment-btn">
                {{ block.settings.button_text }}
              </a>
            {% endif %}

          </div>

        </div>

      {% endfor %}

    </div>

  </div>

</section>

<style>

.pf-subtreatments-section {
  padding: 120px 40px;
  background: #FAF9F6;
  overflow: hidden;
}

.pf-subtreatments-subheading {
  text-align: center;
  font-size: 14px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #6E8B74;
  margin-bottom: 15px;
}

.pf-subtreatments-heading {
  text-align: center;
  font-size: 50px;
  line-height: 1.1;
  color: #2B2B2B;
  margin: 0 0 25px;
}

.pf-subtreatments-description {
  text-align: center;
  max-width: 760px;
  margin: 0 auto 80px;
  color: #666;
  line-height: 1.8;
}

.pf-subtreatments-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 35px;
}

.pf-subtreatment-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: #F5F1EB;
  border-radius: 30px;
  overflow: hidden;
  min-height: 420px;
  opacity: 0;
  transform: translateY(60px);
  transition: all 0.7s ease;
}

.pf-subtreatment-card.show {
  opacity: 1;
  transform: translateY(0);
}

.pf-subtreatment-card:hover {
  transform: translateY(-8px);
}

.pf-subtreatment-image {
  position: relative;
  overflow: hidden;
}

.pf-subtreatment-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 1s ease;
}

.pf-subtreatment-card:hover img {
  transform: scale(1.08);
}

.pf-subtreatment-content {
  padding: 45px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.pf-subtreatment-number {
  font-size: 14px;
  letter-spacing: 2px;
  color: #A67C52;
  margin-bottom: 18px;
}

.pf-subtreatment-content h3 {
  font-size: 42px;
  line-height: 1.1;
  color: #2B2B2B;
  margin-bottom: 20px;
}

.pf-subtreatment-content p {
  color: #666;
  line-height: 1.8;
  margin-bottom: 28px;
}

.pf-subtreatment-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  background: #483C32;
  color: white;
  text-decoration: none;
  padding: 14px 28px;
  border-radius: 100px;
  transition: all 0.3s ease;
}

.pf-subtreatment-btn:hover {
  background: #8d6642;
}

.pf-subtreatment-card:nth-child(even) .pf-subtreatment-image {
  order: 2;
}

.pf-subtreatment-card:nth-child(even) .pf-subtreatment-content {
  order: 1;
}

/* TABLET */

@media(max-width: 1100px){

  .pf-subtreatments-grid {
    grid-template-columns: 1fr;
  }

}

/* MOBILE */

@media(max-width: 768px){

  .pf-subtreatments-section {
    padding: 80px 20px;
  }

  .pf-subtreatments-heading {
    font-size: 40px;
  }

  .pf-subtreatments-description {
    margin-bottom: 50px;
  }

  .pf-subtreatment-card {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .pf-subtreatment-image {
    height: 320px;
  }

  .pf-subtreatment-content {
    padding: 30px 25px;
  }

  .pf-subtreatment-content h3 {
    font-size: 32px;
  }

}

</style>

<script>

document.addEventListener("DOMContentLoaded", function(){

  const treatmentCards = document.querySelectorAll('.reveal-treatment');

  const treatmentObserver = new IntersectionObserver((entries) => {

    entries.forEach((entry, index) => {

      if(entry.isIntersecting){

        setTimeout(() => {
          entry.target.classList.add('show');
        }, index * 120);

      }

    });

  }, {
    threshold: 0.1
  });

  treatmentCards.forEach((card) => {
    treatmentObserver.observe(card);
  });

});

</script>

{% schema %}
{
  "name": "Sub Treatments",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Specialized Care"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Treatments & Support"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "treatment",
      "name": "Treatment",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Treatment Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Treatment Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Treatment Description"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Book Consultation"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PointAndFlow Sub Treatments"
    }
  ]
}
{% endschema %}