{% comment %}
PointAndFlow FAQ + CTA Section
Premium luxury editorial — refined spa aesthetic
Matches pf-treatment-categories + pf-slideshow design system
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

<section class="pf-faq-section" id="pf-faq-{{ section.id }}">

  <!-- Grain -->
  <div class="pf-faq-grain" aria-hidden="true"></div>

  <div class="pf-faq-inner page-width">

    <!-- Header -->
    <header class="pf-faq-header">

      {% if section.settings.subheading != blank %}
        <div class="pf-faq-eyebrow">
          <span class="pf-faq-eyebrow-line" aria-hidden="true"></span>
          <p class="pf-faq-subheading">{{ section.settings.subheading }}</p>
          <span class="pf-faq-eyebrow-line" aria-hidden="true"></span>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="pf-faq-heading">{{ section.settings.heading }}</h2>
      {% endif %}

    </header>

    <!-- Accordion -->
    <div class="pf-faq-wrapper" role="list">

      {% for block in section.blocks %}
        <div
          class="pf-faq-item"
          role="listitem"
          {{ block.shopify_attributes }}
        >

          <button
            class="pf-faq-question"
            aria-expanded="false"
            aria-controls="pf-answer-{{ section.id }}-{{ forloop.index }}"
          >

            <span class="pf-faq-q-number" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>

            <span class="pf-faq-q-text">{{ block.settings.question }}</span>

            <span class="pf-faq-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path class="pf-icon-h" d="M3 9H15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <path class="pf-icon-v" d="M9 3V15" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </span>

          </button>

          <div
            class="pf-faq-answer"
            id="pf-answer-{{ section.id }}-{{ forloop.index }}"
            role="region"
          >
            <div class="pf-faq-answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>

        </div>
      {% endfor %}

    </div>

    <!-- CTA -->
    <div class="pf-faq-cta">

      <!-- Decorative orbs -->
      <div class="pf-cta-orb pf-cta-orb--1" aria-hidden="true"></div>
      <div class="pf-cta-orb pf-cta-orb--2" aria-hidden="true"></div>
      <div class="pf-cta-grain" aria-hidden="true"></div>

      <div class="pf-cta-inner">

        {% if section.settings.cta_subheading != blank %}
          <div class="pf-cta-eyebrow">
            <span class="pf-cta-eyebrow-line" aria-hidden="true"></span>
            <p class="pf-cta-subheading">{{ section.settings.cta_subheading }}</p>
            <span class="pf-cta-eyebrow-line" aria-hidden="true"></span>
          </div>
        {% endif %}

        {% if section.settings.cta_heading != blank %}
          <h3 class="pf-cta-heading">{{ section.settings.cta_heading }}</h3>
        {% endif %}

        {% if section.settings.cta_text != blank %}
          <div class="pf-cta-text">{{ section.settings.cta_text }}</div>
        {% endif %}

        {% if section.settings.cta_button_text != blank %}
          <a href="{{ section.settings.cta_button_link }}" class="pf-cta-btn">
            <span>{{ section.settings.cta_button_text }}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}

      </div>

    </div>

  </div>
</section>

<style>

/* ─── Tokens ─── */
#pf-faq-{{ section.id }} {
  --pf-bg:          #F5F1EA;
  --pf-dark:        #1C1A17;
  --pf-gold:        #B89A6A;
  --pf-gold-light:  #D4B896;
  --pf-text:        #3A3630;
  --pf-muted:       #8C8479;
  --pf-border:      rgba(60, 50, 38, 0.12);
  --pf-cta-bg:      #2A2218;
  --pf-font-serif:  'Cormorant Garamond', Georgia, serif;
  --pf-font-sans:   'Jost', sans-serif;
  --pf-ease-expo:   cubic-bezier(0.16, 1, 0.3, 1);
}

/* ─── Section ─── */
.pf-faq-section {
  position: relative;
  padding: 130px 40px 150px;
  background: var(--pf-bg);
  overflow: hidden;
}

.pf-faq-grain {
  position: absolute;
  inset: -50%;
  width: 200%;
  height: 200%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.022;
  pointer-events: none;
  animation: pf-faq-grain 8s steps(10) infinite;
}

@keyframes pf-faq-grain {
  0%,100% { transform: translate(0,0) }
  10%     { transform: translate(-1%,-1%) }
  20%     { transform: translate(1%,0) }
  30%     { transform: translate(-1%,1%) }
  40%     { transform: translate(0,-1%) }
  50%     { transform: translate(1%,1%) }
  60%     { transform: translate(-1%,0) }
  70%     { transform: translate(0,1%) }
  80%     { transform: translate(1%,-1%) }
  90%     { transform: translate(-1%,1%) }
}

.pf-faq-inner {
  position: relative;
  z-index: 1;
}

/* ─── Header ─── */
.pf-faq-header {
  text-align: center;
  margin-bottom: 80px;
}

.pf-faq-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  margin-bottom: 22px;
}

.pf-faq-eyebrow-line {
  display: block;
  width: 36px;
  height: 1px;
  background: var(--pf-gold);
  opacity: 0.7;
}

.pf-faq-subheading {
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--pf-gold);
  margin: 0;
}

.pf-faq-heading {
  font-family: var(--pf-font-serif);
  font-weight: 300;
  font-size: 68px;
  line-height: 1.05;
  letter-spacing: -0.3px;
  color: var(--pf-dark);
  margin: 0;
}

/* ─── Accordion Wrapper ─── */
.pf-faq-wrapper {
  max-width: 900px;
  margin: 0 auto;
  border-top: 1px solid var(--pf-border);
}

/* ─── FAQ Item ─── */
.pf-faq-item {
  border-bottom: 1px solid var(--pf-border);
  transition: background 0.3s ease;
}

/* ─── Question Button ─── */
.pf-faq-question {
  width: 100%;
  background: transparent;
  border: none;
  padding: 32px 0;
  display: grid;
  grid-template-columns: 42px 1fr 40px;
  align-items: center;
  gap: 0 20px;
  cursor: pointer;
  text-align: left;
  transition: opacity 0.2s ease;
}

.pf-faq-question:hover {
  opacity: 0.82;
}

.pf-faq-q-number {
  font-family: var(--pf-font-serif);
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 2px;
  color: var(--pf-gold);
  opacity: 0.75;
  line-height: 1;
  padding-top: 3px;
}

.pf-faq-q-text {
  font-family: var(--pf-font-serif);
  font-size: 28px;
  font-weight: 300;
  line-height: 1.3;
  color: var(--pf-dark);
}

/* Icon */
.pf-faq-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--pf-border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--pf-gold);
  flex-shrink: 0;
  transition: all 0.4s var(--pf-ease-expo);
  justify-self: end;
}

.pf-faq-item.is-open .pf-faq-icon {
  background: var(--pf-gold);
  border-color: var(--pf-gold);
  color: #fff;
}

.pf-icon-v {
  transform-origin: center;
  transition: transform 0.4s var(--pf-ease-expo), opacity 0.4s ease;
}

.pf-faq-item.is-open .pf-icon-v {
  transform: scaleY(0);
  opacity: 0;
}

/* ─── Answer ─── */
.pf-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.55s var(--pf-ease-expo);
}

.pf-faq-answer-inner {
  display: grid;
  grid-template-columns: 42px 1fr;
  gap: 0 20px;
  padding-bottom: 32px;
  padding-right: 60px;
}

/* pseudo-spacer to align with text column */
.pf-faq-answer-inner::before {
  content: '';
  display: block;
}

.pf-faq-answer-inner p,
.pf-faq-answer-inner li,
.pf-faq-answer-inner div {
  font-family: var(--pf-font-sans);
  font-weight: 300;
  font-size: 15px;
  line-height: 1.9;
  color: var(--pf-muted);
  margin: 0;
}

/* ─── CTA Block ─── */
.pf-faq-cta {
  position: relative;
  margin-top: 120px;
  border-radius: 32px;
  background: var(--pf-cta-bg);
  overflow: hidden;
  padding: 100px 80px;
  text-align: center;
  isolation: isolate;
}

/* Decorative orbs */
.pf-cta-orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.pf-cta-orb--1 {
  width: 560px;
  height: 560px;
  background: radial-gradient(circle, rgba(184,154,106,0.13) 0%, transparent 70%);
  top: -200px;
  right: -140px;
}

.pf-cta-orb--2 {
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(184,154,106,0.07) 0%, transparent 70%);
  bottom: -160px;
  left: -100px;
}

.pf-cta-grain {
  position: absolute;
  inset: -50%;
  width: 200%;
  height: 200%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.035;
  pointer-events: none;
}

.pf-cta-inner {
  position: relative;
  z-index: 2;
  max-width: 720px;
  margin: 0 auto;
}

.pf-cta-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-bottom: 24px;
}

.pf-cta-eyebrow-line {
  display: block;
  width: 32px;
  height: 1px;
  background: var(--pf-gold);
  opacity: 0.6;
}

.pf-cta-subheading {
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--pf-gold);
  margin: 0;
}

.pf-cta-heading {
  font-family: var(--pf-font-serif);
  font-weight: 300;
  font-size: 62px;
  line-height: 1.08;
  letter-spacing: -0.3px;
  color: #fff;
  margin: 0 0 28px;
}

.pf-cta-text {
  font-family: var(--pf-font-sans);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.62);
  margin: 0 auto 40px;
  max-width: 600px;
}

.pf-cta-text p { margin: 0; }

.pf-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--pf-dark);
  background: var(--pf-gold);
  padding: 15px 30px 15px 32px;
  border-radius: 100px;
  border: 1px solid var(--pf-gold);
  transition: all 0.35s ease;
}

.pf-cta-btn svg {
  transition: transform 0.35s var(--pf-ease-expo);
}

.pf-cta-btn:hover {
  background: var(--pf-gold-light);
  border-color: var(--pf-gold-light);
}

.pf-cta-btn:hover svg {
  transform: translateX(4px);
}

/* ─── Scroll reveal ─── */
.pf-faq-header,
.pf-faq-item,
.pf-faq-cta {
  opacity: 0;
  transform: translateY(40px);
  transition:
    opacity 0.85s var(--pf-ease-expo),
    transform 0.85s var(--pf-ease-expo);
}

.pf-faq-header.pf-visible,
.pf-faq-item.pf-visible,
.pf-faq-cta.pf-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ─── Tablet ─── */
@media (max-width: 1100px) {
  .pf-faq-heading  { font-size: 52px; }
  .pf-cta-heading  { font-size: 48px; }
  .pf-faq-cta      { padding: 80px 60px; }
}

/* ─── Mobile ─── */
@media (max-width: 768px) {
  .pf-faq-section  { padding: 80px 20px 100px; }

  .pf-faq-heading  { font-size: 40px; }
  .pf-faq-header   { margin-bottom: 50px; }

  .pf-faq-question {
    grid-template-columns: 32px 1fr 36px;
    padding: 26px 0;
    gap: 0 14px;
  }

  .pf-faq-q-number { font-size: 12px; }
  .pf-faq-q-text   { font-size: 22px; }

  .pf-faq-answer-inner {
    grid-template-columns: 32px 1fr;
    gap: 0 14px;
    padding-right: 0;
    padding-bottom: 24px;
  }

  .pf-faq-cta {
    margin-top: 80px;
    padding: 70px 28px;
    border-radius: 24px;
  }

  .pf-cta-heading  { font-size: 38px; }

  .pf-cta-btn {
    width: 100%;
    justify-content: center;
  }
}

</style>

<script>
(function () {
  document.addEventListener('DOMContentLoaded', function () {

    const section = document.getElementById('pf-faq-{{ section.id }}');
    if (!section) return;

    // ── Accordion ─────────────────────────────────────────
    const items = section.querySelectorAll('.pf-faq-item');

    items.forEach(item => {
      const btn    = item.querySelector('.pf-faq-question');
      const answer = item.querySelector('.pf-faq-answer');

      btn.addEventListener('click', () => {

        const isOpen = item.classList.contains('is-open');

        // Close all
        items.forEach(other => {
          if (other !== item) {
            other.classList.remove('is-open');
            other.querySelector('.pf-faq-question').setAttribute('aria-expanded', 'false');
            other.querySelector('.pf-faq-answer').style.maxHeight = '0';
          }
        });

        // Toggle clicked
        item.classList.toggle('is-open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
        answer.style.maxHeight = isOpen ? '0' : answer.scrollHeight + 'px';
      });
    });

    // ── Scroll reveal ──────────────────────────────────────
    const revealEls = section.querySelectorAll('.pf-faq-header, .pf-faq-item, .pf-faq-cta');

    const observer = new IntersectionObserver(entries => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          // Stagger items slightly
          const delay = entry.target.classList.contains('pf-faq-item')
            ? Array.from(items).indexOf(entry.target) * 70
            : 0;
          setTimeout(() => entry.target.classList.add('pf-visible'), delay);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

  });
})();
</script>

{% schema %}
{
  "name": "FAQ + CTA",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything You Need To Know"
    },
    {
      "type": "text",
      "id": "cta_subheading",
      "label": "CTA Subheading",
      "default": "Begin Your Wellness Journey"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Personalized Care Designed Around You"
    },
    {
      "type": "richtext",
      "id": "cta_text",
      "label": "CTA Text"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Book Consultation"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PointAndFlow FAQ + CTA"
    }
  ]
}
{% endschema %}
