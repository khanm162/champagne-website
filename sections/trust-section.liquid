{% comment %}
PointAndFlow Trust / Why Choose Us Section
Premium luxury editorial — refined spa aesthetic
Matches pf-treatment-categories + pf-slideshow + pf-faq design system
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">

<section class="pf-trust-section" id="pf-trust-{{ section.id }}">

  <div class="pf-trust-grain" aria-hidden="true"></div>

  <!-- Ambient background orb -->
  <div class="pf-trust-orb" aria-hidden="true"></div>

  <div class="pf-trust-inner page-width">

    <!-- Header -->
    <header class="pf-trust-header pf-t-reveal">

      {% if section.settings.subheading != blank %}
        <div class="pf-trust-eyebrow">
          <span class="pf-trust-eyebrow-line" aria-hidden="true"></span>
          <p class="pf-trust-subheading">{{ section.settings.subheading }}</p>
          <span class="pf-trust-eyebrow-line" aria-hidden="true"></span>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="pf-trust-heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="pf-trust-description">{{ section.settings.description }}</div>
      {% endif %}

    </header>

    <!-- Cards -->
    <div class="pf-trust-grid">

      {% for block in section.blocks %}
        <div
          class="pf-trust-card pf-t-reveal"
          style="--card-i: {{ forloop.index }};"
          {{ block.shopify_attributes }}
        >

          <!-- Card number -->
          <span class="pf-trust-card-num" aria-hidden="true">
            {{ forloop.index | prepend: '0' | slice: -2, 2 }}
          </span>

          <!-- Icon -->
          <div class="pf-trust-icon-wrap" aria-hidden="true">
            {% case block.settings.icon_type %}

              {% when 'specialist' %}
              <!-- Acupuncture / needle -->
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="2" x2="12" y2="14"/>
                <path d="M9 11l3 3 3-3"/>
                <path d="M8 18h8"/>
                <path d="M10 21h4"/>
              </svg>

              {% when 'healing' %}
              <!-- Globe / holistic -->
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20"/>
                <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
              </svg>

              {% when 'treatment' %}
              <!-- Person / wellness -->
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="7" r="3"/>
                <path d="M5 21v-2a7 7 0 0114 0v2"/>
                <path d="M9 14l1.5 3 1.5-2 1.5 2L15 14"/>
              </svg>

              {% when 'location' %}
              <!-- Map pin -->
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2C8.686 2 6 4.686 6 8c0 4.418 6 12 6 12s6-7.582 6-12c0-3.314-2.686-6-6-6z"/>
                <circle cx="12" cy="8" r="2"/>
              </svg>

            {% endcase %}
          </div>

          <!-- Divider -->
          <div class="pf-trust-card-line" aria-hidden="true"></div>

          {% if block.settings.title != blank %}
            <h3 class="pf-trust-card-title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="pf-trust-card-text">{{ block.settings.text }}</p>
          {% endif %}

        </div>
      {% endfor %}

    </div>

  </div>
</section>

<style>

/* ─── Tokens ─── */
#pf-trust-{{ section.id }} {
  --pf-bg:         #EDE8E1;
  --pf-dark:       #1C1A17;
  --pf-gold:       #B89A6A;
  --pf-gold-light: #D4B896;
  --pf-text:       #3A3630;
  --pf-muted:      #8C8479;
  --pf-card-bg:    #F7F3EE;
  --pf-border:     rgba(60, 50, 38, 0.10);
  --pf-font-serif: 'Cormorant Garamond', Georgia, serif;
  --pf-font-sans:  'Jost', sans-serif;
  --pf-ease-expo:  cubic-bezier(0.16, 1, 0.3, 1);
}

/* ─── Section ─── */
.pf-trust-section {
  position: relative;
  padding: 130px 40px 150px;
  background: var(--pf-bg);
  overflow: hidden;
}

/* Grain */
.pf-trust-grain {
  position: absolute;
  inset: -50%;
  width: 200%;
  height: 200%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.022;
  pointer-events: none;
  animation: pf-trust-grain 8s steps(10) infinite;
}

@keyframes pf-trust-grain {
  0%,100% { transform: translate(0,0) }
  10%     { transform: translate(-1%,-1%) }
  20%     { transform: translate(1%,0) }
  30%     { transform: translate(-1%,1%) }
  40%     { transform: translate(0,-1%) }
  50%     { transform: translate(1%,1%) }
  60%     { transform: translate(-1%,0) }
  70%     { transform: translate(0,1%) }
  80%     { transform: translate(1%,-1%) }
  90%     { transform: translate(-1%,1%) }
}

/* Ambient orb */
.pf-trust-orb {
  position: absolute;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(184,154,106,0.09) 0%, transparent 70%);
  top: -100px;
  right: -200px;
  pointer-events: none;
}

.pf-trust-inner {
  position: relative;
  z-index: 1;
}

/* ─── Header ─── */
.pf-trust-header {
  text-align: center;
  margin-bottom: 80px;
}

.pf-trust-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18px;
  margin-bottom: 22px;
}

.pf-trust-eyebrow-line {
  display: block;
  width: 36px;
  height: 1px;
  background: var(--pf-gold);
  opacity: 0.7;
}

.pf-trust-subheading {
  font-family: var(--pf-font-sans);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  color: var(--pf-gold);
  margin: 0;
}

.pf-trust-heading {
  font-family: var(--pf-font-serif);
  font-weight: 300;
  font-size: 68px;
  line-height: 1.05;
  letter-spacing: -0.3px;
  color: var(--pf-dark);
  margin: 0 0 24px;
}

.pf-trust-description {
  font-family: var(--pf-font-sans);
  font-weight: 300;
  font-size: 16px;
  line-height: 1.9;
  color: var(--pf-muted);
  max-width: 640px;
  margin: 0 auto;
}

.pf-trust-description p { margin: 0; }

/* ─── Grid ─── */
.pf-trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

/* ─── Card ─── */
.pf-trust-card {
  position: relative;
  background: var(--pf-card-bg);
  border: 1px solid var(--pf-border);
  border-radius: 24px;
  padding: 42px 32px 40px;
  display: flex;
  flex-direction: column;
  gap: 0;
  overflow: hidden;
  transition:
    transform 0.55s var(--pf-ease-expo),
    box-shadow 0.55s var(--pf-ease-expo),
    background 0.4s ease;
}

/* Subtle inner shine on hover */
.pf-trust-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(184,154,106,0.08) 0%, transparent 65%);
  opacity: 0;
  transition: opacity 0.5s ease;
  pointer-events: none;
  border-radius: inherit;
}

.pf-trust-card:hover {
  transform: translateY(-10px);
  box-shadow:
    0 24px 60px rgba(28, 26, 23, 0.10),
    0 4px 16px rgba(28, 26, 23, 0.06);
}

.pf-trust-card:hover::before {
  opacity: 1;
}

/* Card number */
.pf-trust-card-num {
  position: absolute;
  top: 28px;
  right: 28px;
  font-family: var(--pf-font-serif);
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 2px;
  color: var(--pf-gold);
  opacity: 0.55;
  line-height: 1;
}

/* Icon */
.pf-trust-icon-wrap {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  background: rgba(184, 154, 106, 0.10);
  border: 1px solid rgba(184, 154, 106, 0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--pf-gold);
  margin-bottom: 28px;
  flex-shrink: 0;
  transition: all 0.4s var(--pf-ease-expo);
}

.pf-trust-card:hover .pf-trust-icon-wrap {
  background: var(--pf-gold);
  border-color: var(--pf-gold);
  color: #fff;
  transform: scale(1.08);
}

/* Divider */
.pf-trust-card-line {
  width: 28px;
  height: 1px;
  background: var(--pf-gold);
  opacity: 0.5;
  margin-bottom: 20px;
  flex-shrink: 0;
  transition: width 0.4s var(--pf-ease-expo), opacity 0.4s ease;
}

.pf-trust-card:hover .pf-trust-card-line {
  width: 44px;
  opacity: 0.8;
}

/* Title */
.pf-trust-card-title {
  font-family: var(--pf-font-serif);
  font-weight: 300;
  font-size: 26px;
  line-height: 1.2;
  color: var(--pf-dark);
  margin: 0 0 14px;
}

/* Body */
.pf-trust-card-text {
  font-family: var(--pf-font-sans);
  font-weight: 300;
  font-size: 14px;
  line-height: 1.85;
  color: var(--pf-muted);
  margin: 0;
}

/* ─── Scroll reveal ─── */
.pf-t-reveal {
  opacity: 0;
  transform: translateY(40px);
  transition:
    opacity 0.85s var(--pf-ease-expo),
    transform 0.85s var(--pf-ease-expo);
}

.pf-t-reveal.pf-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Cards stagger via CSS var */
.pf-trust-card.pf-t-reveal {
  transition-delay: calc((var(--card-i) - 1) * 80ms);
}

/* ─── Tablet ─── */
@media (max-width: 1100px) {
  .pf-trust-grid    { grid-template-columns: repeat(2, 1fr); }
  .pf-trust-heading { font-size: 52px; }
}

/* ─── Mobile ─── */
@media (max-width: 768px) {
  .pf-trust-section  { padding: 80px 20px 100px; }
  .pf-trust-heading  { font-size: 40px; }
  .pf-trust-header   { margin-bottom: 50px; }
  .pf-trust-grid     { grid-template-columns: 1fr; gap: 10px; }

  .pf-trust-card {
    padding: 34px 28px 32px;
    border-radius: 20px;
  }
}

</style>

<script>
(function () {
  document.addEventListener('DOMContentLoaded', function () {

    const section = document.getElementById('pf-trust-{{ section.id }}');
    if (!section) return;

    const revealEls = section.querySelectorAll('.pf-t-reveal');

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('pf-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach(el => observer.observe(el));

  });
})();
</script>

{% schema %}
{
  "name": "PointAndFlow Trust",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Why Choose PointAndFlow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Personalized Healing Rooted in Balance"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "trust_card",
      "name": "Trust Card",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Select Icon",
          "options": [
            { "value": "specialist", "label": "Certified Specialists" },
            { "value": "healing",    "label": "Natural Healing" },
            { "value": "treatment",  "label": "Personalized Treatments" },
            { "value": "location",   "label": "Location" }
          ],
          "default": "specialist"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PointAndFlow Trust Section"
    }
  ]
}
{% endschema %}
