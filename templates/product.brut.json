    "story": {
      "type": "champagne-story",
      "blocks": {
        "vintage": {
          "type": "chapter",
          "settings": {
            "media_position": "right",
            "eyebrow": "T22 · 161st Year Tirage",
            "heading": "De Lossy Brut",
            "body": "<p>The 2021 season tested us — spring rain and summer storms meant only the most dedicated growers secured truly superior fruit. Our team crafted twenty-five blends before selecting this one: the bright, freshest fruit of Harvest 2021 layered with the complexity of reserve wines dating back to 2013.</p><p><strong>The Blend:</strong> 29% Chardonnay · 36% Pinot Noir · 35% Meunier</p>"
          }
        },
        "tasting": {
          "type": "chapter",
          "settings": {
            "media_position": "left",
            "eyebrow": "On the Nose & Palate",
            "heading": "Tasting Notes",
            "body": "<p><strong>Palate:</strong> A wealth of fresh red berries — strawberry reminiscent of fine patisserie — lifted by fresh clementine and candied orange peel.</p><p><strong>Nose:</strong> Red currant, blackberries and ripe apricot.</p>"
          }
        }
      },
      "block_order": ["vintage", "tasting"],
      "settings": {
        "subheading": "Discover the Cuvée",
        "heading": "A Toast to Life",
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 100,
        "padding-block-end": 80
      }
    },
    "pairings": {
      "type": "champagne-pairings",
      "blocks": {
        "p1": {
          "type": "pairing",
          "settings": {
            "dish": "Lobster with citrus beurre blanc",
            "note": "The richness of the lobster meets the wine's bright acidity for a clean, elegant finish."
          }
        },
        "p2": {
          "type": "pairing",
          "settings": {
            "dish": "Grilled scallops with citrus glaze",
            "note": "Sweet, caramelised scallops echo the cuvée's orange-peel notes."
          }
        },
        "p3": {
          "type": "pairing",
          "settings": {
            "dish": "Prosciutto with melon or figs",
            "note": "Salt and ripe fruit play against the fresh red-berry character."
          }
        },
        "p4": {
          "type": "pairing",
          "settings": {
            "dish": "Strawberry or raspberry tart",
            "note": "A patisserie pairing that mirrors the wine's own strawberry tone."
          }
        },
        "p5": {
          "type": "pairing",
          "settings": {
            "dish": "Citrus-infused pastries or sorbet",
            "note": "Bright citrus desserts lengthen the finish without overwhelming it."
          }
        }
      },
      "block_order": ["p1", "p2", "p3", "p4", "p5"],
      "settings": {
        "subheading": "Pairing Suggestions",
        "heading": "Perfect with the Brut",
        "intro": "<p>Foods that balance richness and freshness bring out the cuvée's acidity and depth.</p>",
        "section_width": "page-width",
        "color_scheme": "scheme-1",
        "padding-block-start": 24,
        "padding-block-end": 88
